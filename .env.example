# --- Inference confidence thresholds ---
# Confidence of the "bread" label required to treat a picture as bread.
BREAD_DETECTION_CONFIDENCE=0.5
# Lower threshold used on an "are you sure" retry. Should be < BREAD_DETECTION_CONFIDENCE.
OVERRIDE_DETECTION_CONFIDENCE=0.1

# --- Discord ---
DISCORD_TOKEN=your-bot-token-here
# Channels where bread detection is active (list of channel ids).
DISCORD_BREAD_CHANNELS=[1,2,4,5]
# Roles allowed to trigger bread detection (list of role ids).
DISCORD_BREAD_ROLE=[1]

# --- Storage ---
# SQLite database (reused from the Python bot).
DB_DATA_PATH=dbdata/messages.db
# Where attachments, plots, and annotated predictions are written.
DOWNLOADS_PATH=downloads

# --- Inference microservice ---
INFERENCE_SERVICE_URL=http://localhost:8000

# --- Read-only stats HTTP server ---
# Listen address for the stats API + /healthz.
ADMIN_API_ADDR=:8080
# Optional bearer token guarding /api/* (leave unset to disable auth).
# ADMIN_API_TOKEN=

# --- Misc ---
DEBUG=false
